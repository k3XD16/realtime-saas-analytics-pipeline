# Airflow
AIRFLOW_UID=50000
AIRFLOW__CORE__LOAD_EXAMPLES=false

# Fernet Key
FERNET_KEY=generate_a_secure_fernet_key_for_airflow

# Providers to install (Unpinned for Airflow 3 compatibility)
_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-databricks apache-airflow-providers-snowflake apache-airflow-providers-amazon sqlalchemy>=2.0.0 loguru requests

# Databricks
DATABRICKS_HOST=https://adb-xxxxx.azuredatabricks.net
DATABRICKS_TOKEN=your_personal_access_token

# Databricks Job IDs
DATABRICKS_BRONZE_JOB_ID=101
DATABRICKS_SILVER_JOB_ID=102
DATABRICKS_GOLD_JOB_ID=103

# Kafka / Schema Registry
SCHEMA_REGISTRY_URL=https://psrc-xxxxx.us-east-2.aws.confluent.cloud
SCHEMA_REGISTRY_API_KEY=your_sr_api_key
SCHEMA_REGISTRY_API_SECRET=your_sr_api_secret