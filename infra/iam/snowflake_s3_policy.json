{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SnowflakeS3ReadOnly",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:ListBucket",
