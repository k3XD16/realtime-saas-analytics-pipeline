{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DatabricksS3ReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetLifecycleConfiguration",
        "s3:PutLifecycleConfiguration"
      ],
      "Resource": [
        "arn:aws:s3:::realtime-saas-analytics-pipeline",
        "arn:aws:s3:::realtime-saas-analytics-pipeline/*"
      ]
    }
  ]
}